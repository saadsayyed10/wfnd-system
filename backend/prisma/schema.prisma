// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id              String    @id @default(uuid())
  clerkId         String    @unique
  name            String
  email           String    @unique
  profile_picture String?
  user_type       UserType?
  approval        Boolean   @default(false)
  created_at      DateTime  @default(now())
}

model workers {
  id            String   @id @default(uuid())
  name          String
  daily_payment Float
  created_at    DateTime @default(now())

  attendance attendance[]
  payslips   payslips[]
}

model attendance {
  id            String         @id @default(uuid())
  login         String?
  logout        String?
  date          DateTime
  type          AttendanceType @default(ABSENT)
  totalHours    Float          @default(0)
  overtimeHours Float          @default(0)

  workerId String?
  workers  workers? @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, date])
}

model payslips {
  id             String   @id @default(uuid())
  week_start     DateTime
  week_end       DateTime
  payslip_data   Json[]
  total_days     Int
  actual_days    Float
  overtime_total Float
  weekly_wage    Int
  created_at     DateTime @default(now())
  workers        workers? @relation(fields: [workersId], references: [id])
  workersId      String?

  @@unique([workersId, week_start, week_end])
  @@index([week_start, week_end])
}

enum AttendanceType {
  PRESENT
  ABSENT
  HALFDAY
  OVERTIME
}

enum UserType {
  ADMIN
  MODERATOR
}
